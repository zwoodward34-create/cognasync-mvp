# ── CognaSync LOCAL DEV env ───────────────────────────────────────────────────
# Copy to `.env.local` and fill in. NEVER point this at the production Supabase
# project — local dev must use a separate dev project with SYNTHETIC data only.
# `.env.local` is git-ignored; do not commit real keys.

# ── Required to boot ──────────────────────────────────────────────────────────
SECRET_KEY=dev-only-change-me-to-any-long-random-string
FLASK_ENV=development
FLASK_PORT=5002
ALLOWED_ORIGIN=http://localhost:5002
APP_URL=http://localhost:5002

# ── Required: your DEV Supabase project (Settings > API) ──────────────────────
# A SECOND project, not production. See docs/local-dev.md.
SUPABASE_URL=https://YOUR-DEV-PROJECT.supabase.co
SUPABASE_KEY=YOUR-DEV-anon-key
SUPABASE_SERVICE_KEY=YOUR-DEV-service-role-key
SUPABASE_JWT_SECRET=YOUR-DEV-jwt-secret

# ── Required for brief generation (real calls, ~pennies on Haiku) ─────────────
# Omit/leave dummy if you only need to click around the UI without generating briefs.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Dummy-OK locally — features below won't actually send, but the app boots ──
# Email (registration/verification): use scripts/local.sh seed to create accounts
# directly via the service key, which bypasses email entirely.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=dev@example.com
SMTP_PASS=unused-locally
FROM_EMAIL=dev@example.com
ADMIN_EMAIL=dev@example.com

# Audio transcription (not needed to view/print briefs)
ASSEMBLYAI_API_KEY=unused-locally

# SMS (not needed to view/print briefs)
TWILIO_ACCOUNT_SID=ACdevdevdevdevdevdevdevdevdevdevdev
TWILIO_AUTH_TOKEN=unused-locally
TWILIO_PHONE_NUMBER=+15555550100
TWILIO_FLOW_SID_MED=FWdevdevdevdevdevdevdevdevdevdevdev
TWILIO_FLOW_SID_SHORT=FWdevdevdevdevdevdevdevdevdevdevdev
TWILIO_FLOW_SID_FULL=FWdevdevdevdevdevdevdevdevdevdevdev
TWILIO_FLOW_SID_VOICE=FWdevdevdevdevdevdevdevdevdevdevdev

# Internal cron auth (not needed locally)
INTERNAL_SECRET=dev-only-internal-secret
