ANTHROPIC_API_KEY=sk-ant-...
ASSEMBLYAI_API_KEY=your-assemblyai-api-key   # Required for audio transcription — get from assemblyai.com
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change-this-to-a-long-random-secret-key
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Supabase — all three required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# Found in Supabase dashboard: Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Restrict CORS to your deployed domain in production
ALLOWED_ORIGIN=https://your-domain.com

# Email — required for registration verification and admin notifications
# Use Gmail with an App Password, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-address@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-sending-address@gmail.com

# App base URL — used to build email links (no trailing slash)
APP_URL=https://your-app.onrender.com

# Admin notification email for new account approvals
ADMIN_EMAIL=zwoodward@cognasync.com

# ── Twilio — SMS delivery ─────────────────────────────────────────────────────
# Get from: console.twilio.com > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567   # E.164 format — your Twilio sending number

# Studio Flow SIDs — created in Twilio Studio, one per flow
# Get each SID from: Studio > Flows > [Flow Name] > Properties
TWILIO_FLOW_SID_MED=FWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx     # Flow 1: Medication adherence
TWILIO_FLOW_SID_SHORT=FWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Flow 2: Short check-in
TWILIO_FLOW_SID_FULL=FWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # Flow 3: Full pre-appt check-in
TWILIO_FLOW_SID_VOICE=FWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Flow 4: Standalone voice invite

# Internal cron authentication — generate a long random string (e.g. openssl rand -hex 32)
# Set this same value as INTERNAL_SECRET on all Render cron job services
INTERNAL_SECRET=change-this-to-a-long-random-secret

# Required for voice recording link generation (no trailing slash)
# APP_URL is already defined above — make sure it's set in production
# APP_URL=https://your-app.onrender.com
